#作业路径规划请求参数
geometry_msgs/Polygon polygon  #区块坐标
int8 path_mode      #路径规划模式
float64 path_width   #耕宽
int32   request_id   #请求ID,客户端用于区分是否是自己请求的数据
float64 car_radius
---

#返回路径信息
int32 WORK_DONE = 0     #工作
int32 WORK_START =1     #起点
int32 WORK_END = 2      #一行结束
int32 WORK_FINISH = 3   #结束

int32 request_id    
std_msgs/Header header
geometry_msgs/PoseStamped[] poses
int8[] status 
int32 err_code