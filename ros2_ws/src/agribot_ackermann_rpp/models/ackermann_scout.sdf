    <plugin name='ackermann_drive' filename='libagribot_ackermann_rpp_drive.so'>
      <ros>
        <namespace>/</namespace>
      </ros>
      <cmd_vel_topic>/nav2/cmd_vel_safe</cmd_vel_topic>
      <odom_topic>/odom</odom_topic>
      <joint_state_topic>/joint_states</joint_state_topic>
      <odom_frame>odom</odom_frame>
      <base_frame>base_link</base_frame>
      <wheelbase>0.498</wheelbase>
      <track_width>0.58306</track_width>
      <wheel_radius>0.16459</wheel_radius>
      <max_steering_angle>0.6</max_steering_angle>
      <max_steering_rate>1.2</max_steering_rate>
      <max_speed>1.0</max_speed>
      <max_accel>1.5</max_accel>
      <min_speed_for_curvature>0.05</min_speed_for_curvature>
      <command_timeout>1.5</command_timeout>
      <publish_rate>30.0</publish_rate>
      <publish_tf>true</publish_tf>
      <wheel_torque>200.0</wheel_torque>
      <sensor_model_name>ackermann_scout_sensor</sensor_model_name>
