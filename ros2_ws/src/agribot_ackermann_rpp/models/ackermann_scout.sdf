    <joint name='front_left_steering_joint' type='revolute'>
      <pose relative_to='base_link'>0.249 0.29153 -0.0702 0 0 0</pose>
      <parent>base_link</parent>
      <child>front_left_steering_block_link</child>
      <axis>
