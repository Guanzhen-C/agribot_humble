    </visual>
    <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.11653" radius="0.16459"/>
      </geometry>
      <contact>
        <ode>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </collision>
  </link>
  <joint name="rear_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel_link"/>
    <origin rpy="0 0 0" xyz="-0.249 -0.29153 -0.0702"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <dynamics damping="0.0" friction="20"/>
  </joint>
  <link name="front_mount"/>
  <joint name="front_mount_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.325 0 0.112701"/>
    <parent link="base_link"/>
    <child link="front_mount"/>
  </joint>
  <link name="rear_mount"/>
  <joint name="rear_mount_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.325 0 0.112701"/>
    <parent link="base_link"/>
    <child link="rear_mount"/>
  </joint>
  <!-- Spawn chassis: No top chassis in Scout -->
  <!-- link name="top_chassis_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://scout_description/meshes/top_chassis.dae" />
        </geometry>
      </visual>
    </link -->
  <!-- Attach chassis to the robot -->
  <!-- joint name="top_chassis_joint" type="fixed">
      <parent link="base_link" />
      <child link="top_chassis_link" />
    </joint -->
  <link name="top_plate_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://scout_description/meshes/top_plate.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://scout_description/meshes/top_plate.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- Attach top plate -->
  <joint name="top_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_plate_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.12"/>
  </joint>
  <!-- Top plate front link -->
  <joint name="top_plate_front_joint" type="fixed">
    <parent link="top_plate_link"/>
    <child link="top_plate_front_link"/>
    <origin rpy="0 0 0" xyz="0.36367 0 0.00639"/>
  </joint>
  <!-- Top plate rear link-->
  <joint name="top_plate_rear_joint" type="fixed">
    <parent link="top_plate_link"/>
    <child link="top_plate_rear_link"/>
    <origin rpy="0 0 0" xyz="-0.36633 0 0.00639"/>
  </joint>
  <link name="top_plate_front_link"/>
  <link name="top_plate_rear_link"/>
  <link name="base_laser_mount">
    <visual>
      <origin rpy="0 0 -1.570795" xyz="0 0 0"/>
      <geometry>
        <!-- Origin of this mesh is the base of the bracket. -->
        <mesh filename="package://scout_description/meshes/accessories/ydlidar_mount.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 .0585"/>
      <geometry>
        <box size=".1 .108 .117"/>
      </geometry>
    </collision>
  </link>
  <joint name="base_laser_joint" type="fixed">
    <!-- This offset is from the base of the bracket to the LIDAR's focal point. -->
    <origin rpy="3.14159 0 0" xyz="0.0352 0 0.0566"/>
    <parent link="base_laser_mount"/>
    <child link="base_laser"/>
  </joint>
  <link name="base_laser">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.00029774 0.0066667 0.00013047"/>
      <mass value="0.15717"/>
      <inertia ixx="6.7885E-05" ixy="-1.3987E-07" ixz="-8.1554E-07" iyy="0.00013173" iyz="-9.0932E-08" izz="7.1972E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://scout_description/meshes/accessories/ydlidar.dae"/>
      </geometry>
      <material name="">
        <color rgba="0.64706 0.61961 0.58824 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://scout_description/meshes/accessories/ydlidar.dae"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="base_laser">
    <turnGravityOff>true</turnGravityOff>
    <sensor name="base_laser" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>50</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-1.5708</min_angle>
            <max_angle>1.5708</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.65</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.001</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="base_laser_scan">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <frame_name>base_laser</frame_name>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>
  <joint name="laser_mount_joint" type="fixed">
    <origin rpy="0.0 0.0 0.0" xyz="0.1206 0.0 0.0"/>
    <parent link="top_plate_link"/>
    <child link="base_laser_mount"/>
  </joint>
  <link name="sensor_arch_base_link"/>
  <!-- Spawn the sensor arch link -->
  <link name="sensor_arch_mount_link">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <visual>
      <geometry>
        <mesh filename="package://scout_description/meshes/accessories/300_mm_sensor_arch.dae"/>
      </geometry>
    </visual>
  </link>
  <joint name="sensor_arch_base_link_joint" type="fixed">
    <parent link="top_plate_link"/>
    <child link="sensor_arch_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <!-- Attach the sensor arch to the top plate -->
  <joint name="sensor_arch_mount" type="fixed">
    <parent link="sensor_arch_base_link"/>
    <child link="sensor_arch_mount_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.3"/>
  </joint>
  <link name="realsense_mountpoint"/>
  <joint name="realsense_mountpoint_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="sensor_arch_mount_link"/>
    <child link="realsense_mountpoint"/>
  </joint>
  <link name="camera_realsense_lens"/>
  <joint name="camera_realsense_lens_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="realsense_mountpoint"/>
    <child link="camera_realsense_lens"/>
  </joint>
  <joint name="camera_realsense_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.025 0 0"/>
    <parent link="camera_realsense_lens"/>
    <child link="camera_realsense"/>
  </joint>
  <!-- this link is the origin for the camera's data -->
  <link name="camera_realsense"/>
  <!--
        The gazebo plugin aligns the depth data with the Z axis, with X=left and Y=up
        ROS expects the depth data along the X axis, with Y=left and Z=up
        This link only exists to give the gazebo plugin the correctly-oriented frame
      -->
  <link name="camera_realsense_gazebo"/>
  <joint name="camera_realsense_gazebo_joint" type="fixed">
    <parent link="camera_realsense"/>
    <child link="camera_realsense_gazebo"/>
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0.0 0 0"/>
  </joint>
  <gazebo reference="camera_realsense">
    <turnGravityOff>true</turnGravityOff>
    <sensor name="camera_realsense_depth" type="depth">
      <update_rate>30</update_rate>
      <camera>
        <!-- 75x65 degree FOV for the depth sensor -->
        <horizontal_fov>1.5184351666666667</horizontal_fov>
        <vertical_fov>1.0122901111111111</vertical_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <!-- TODO: check what format the Realsense hardware delivers and set this to match! -->
          <format>RGB_INT8</format>
        </image>
        <clip>
          <!-- give the color sensor a maximum range of 50m so that the simulation renders nicely -->
          <near>0.01</near>
          <far>50.0</far>
        </clip>
        <depth_camera/>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="kinect_controller">
        <ros>
          <namespace>/</namespace>
          <remapping>camera/image_raw:=camera/color/image_raw</remapping>
          <remapping>camera/camera_info:=camera/color/camera_info</remapping>
          <remapping>camera/depth/image_raw:=camera/depth/image_rect_raw</remapping>
          <remapping>camera/depth/camera_info:=camera/depth/camera_info</remapping>
          <remapping>camera/points:=camera/depth/color/points</remapping>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera_realsense_gazebo</frame_name>
        <min_depth>0.105</min_depth>
        <max_depth>8.0</max_depth>
        <hack_baseline>0.0</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>
  <!-- This file is a placeholder which is included by default from
       scout.urdf.xacro. If a robot is being customized and requires
       additional URDF, set the SCOUT_URDF_EXTRAS environment variable
       to the full path of the file you would like included. -->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="scout_diff_drive">
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <num_wheel_pairs>2</num_wheel_pairs>
      <left_joint>front_left_wheel</left_joint>
      <right_joint>front_right_wheel</right_joint>
      <left_joint>rear_left_wheel</left_joint>
      <right_joint>rear_right_wheel</right_joint>
      <wheel_separation>0.58306</wheel_separation>
      <wheel_separation>0.58306</wheel_separation>
      <wheel_diameter>0.32918</wheel_diameter>
      <wheel_diameter>0.32918</wheel_diameter>
      <update_rate>100.0</update_rate>
      <max_wheel_torque>200.0</max_wheel_torque>
      <max_wheel_acceleration>20.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros_joint_state_publisher.so" name="scout_joint_state_publisher">
      <ros>
        <namespace>/</namespace>
        <remapping>joint_states:=joint_states_gazebo</remapping>
      </ros>
      <update_rate>50.0</update_rate>
      <joint_name>front_left_wheel</joint_name>
      <joint_name>front_right_wheel</joint_name>
      <joint_name>rear_left_wheel</joint_name>
      <joint_name>rear_right_wheel</joint_name>
    </plugin>
  </gazebo>
  <!-- kp spring constant, kd damping constant -->
  <gazebo reference="front_left_wheel_link">
    <mu1>1.8</mu1>
    <mu2>1.5</mu2>
    <kp>1000000000.0</kp>
    <kd>0.0</kd>
    <minDepth>0.001</minDepth>
    <fdir1>1 0 0</fdir1>
  </gazebo>
  <gazebo reference="front_right_wheel_link">
    <mu1>1.8</mu1>
    <mu2>1.5</mu2>
    <kp>1000000000.0</kp>
    <kd>0.0</kd>
    <minDepth>0.001</minDepth>
    <fdir1>1 0 0</fdir1>
  </gazebo>
  <gazebo reference="rear_left_wheel_link">
    <mu1>1.8</mu1>
    <mu2>1.5</mu2>
    <kp>1000000000.0</kp>
    <kd>0.0</kd>
    <minDepth>0.001</minDepth>
    <fdir1>1 0 0</fdir1>
  </gazebo>
  <gazebo reference="rear_right_wheel_link">
    <mu1>1.8</mu1>
    <mu2>1.5</mu2>
    <kp>1000000000.0</kp>
    <kd>0.0</kd>
    <minDepth>0.001</minDepth>
    <fdir1>1 0 0</fdir1>
    <!--maxContacts value="64"/-->
  </gazebo>
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50.0</update_rate>
      <visualize>false</visualize>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.005</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_controller">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo reference="base_link">
    <sensor name="gps_sensor" type="gps">
      <always_on>true</always_on>
      <update_rate>40.0</update_rate>
      <visualize>false</visualize>
      <gps>
        <position_sensing>
          <horizontal>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.0001</stddev>
            </noise>
          </horizontal>
          <vertical>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.0001</stddev>
            </noise>
          </vertical>
        </position_sensing>
      </gps>
      <plugin filename="libgazebo_ros_gps_sensor.so" name="gps_controller">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=navsat/fix</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>
  <!-- 3D Position Interface for Ground Truth -->
  <gazebo>
    <plugin filename="libgazebo_ros_p3d.so" name="p3d">
      <ros>
        <namespace>/</namespace>
        <remapping>odom:=base_pose_ground_truth</remapping>
      </ros>
      <body_name>base_link</body_name>
      <update_rate>100.0</update_rate>
    </plugin>
  </gazebo>
</robot>
