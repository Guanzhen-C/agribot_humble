    <collision>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.11653" radius="0.16459"/>
      </geometry>
      <contact>
        <ode>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </collision>
  </link>
  <joint name="rear_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel_link"/>
    <origin rpy="0 0 0" xyz="-0.249 0.29153 -0.0702"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
    <dynamics damping="0.0" friction="20"/>
  </joint>
  <link name="rear_right_wheel_link">
    <inertial>
      <mass value="8"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.1171"/>
    </inertial>
    <visual>
      <origin rpy="3.14159 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://scout_description/meshes/wheel.dae"/>
